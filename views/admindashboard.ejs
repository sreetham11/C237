<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .content {
            margin-left: 220px; /* push content to the right of sidebar */
            padding: 20px;
        }
    </style>
</head>
<body>
    <!-- Header / Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
        <div class="container-fluid">
            <!-- Logo + Title -->
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="/images/logo.png" alt="ResellVault Logo" width="40" height="40" class="me-2">
                ResellVault
            </a>
        </div>
    </nav>

    <!-- Sidebar -->
    <%- include('partials/sidebar') %>

    <!-- Main content -->
    <div class="content" id="content">
        <div class="container" style="margin-top: 80px;">
            <h1>Admin Dashboard</h1>
            <p>Welcome, <%= user.username %> (Admin)</p>
            
            <!-- Action buttons -->
            <a href="/admin/moderateListings" class="btn btn-success">Moderate Listings</a>
            <a href="/products" class="btn btn-primary">Manage Products</a>
            <a href="/users" class="btn btn-warning">Manage Users</a>

            <!-- Recent Registrations -->
            <div class="mt-5">
                <h2>Recent Registrations</h2>
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>User ID</th>
                            <th>Username</th>
                            <th>Email</th>
                            <th>Registered At</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (recentUsers && recentUsers.length > 0) { %>
                            <% recentUsers.forEach(function(user) { %>
                                <tr>
                                    <td><%= user.id %></td>
                                    <td><%= user.username %></td>
                                    <td><%= user.email %></td>
                                    <td><%= user.registered_at %></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" class="text-center">No recent registrations</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>
