<!DOCTYPE html>
<html>
<head>
    <title>User Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        .profile-pic {
            width: 120px;
            height: 120px;
            object-fit: cover;
            border-radius: 50%;
            border: 3px solid #343a40;
        }
        .feature-table {
            margin-top: 40px;
        }
        .feature-table td {
            padding: 20px;
            text-align: center;
            background-color: #f8f9fa;
            border: 1px solid #dee2e6;
        }
        .feature-table .btn {
            font-size: 0.85rem;
            margin-top: 8px;
            width: 120px;
            white-space: nowrap;
        }
        .feature-table i {
            font-size: 1.5rem;
            display: block;
            margin-bottom: 5px;
            color: #343a40;
        }
    </style>
</head>
<body>
    <!-- Navbar -->
    <%- include('partials/navbar') %>

    <!-- Sidebar -->
    <%- include('partials/sidebar') %>

    <!-- Main content -->
    <div class="content" id="content">
        <div class="container text-center" style="margin-top: 100px;">
            <h1>User Dashboard</h1>
            <p>Welcome, <%= user.username %> (<%= user.role %>)</p>

            <!-- Profile Picture -->
            <img src="/images/default-pfp.png" alt="Profile Picture" class="profile-pic mt-3">
            <p class="mt-2"><small>Profile picture upload coming soon in Settings</small></p>

            <!-- Feature Buttons Table -->
            <table class="table feature-table">
                <tr>
                    <td>
                        <i class="bi bi-box-seam"></i>
                        <a href="/products" class="btn btn-primary text-capitalize">my products</a>
                    </td>
                    <td>
                        <i class="bi bi-shop"></i>
                        <a href="/" class="btn btn-primary text-capitalize">listings</a>
                    </td>
                    <td>
                        <i class="bi bi-cash-stack"></i>
                        <a href="/sales" class="btn btn-primary text-capitalize">sales</a>
                    </td>
                    <td>
                        <i class="bi bi-gear"></i>
                        <a href="/settings" class="btn btn-primary text-capitalize">settings</a>
                    </td>
                </tr>
            </table>
        </div>
    </div>
</body>
</html>
