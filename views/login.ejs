<!DOCTYPE html>
<html>
<head>
    <title>Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
        }
        .login-container {
            max-width: 400px;
            margin: 100px auto; /* center vertically and horizontally */
            padding: 30px;
            background: #fff;
            border-radius: 8px;
            box-shadow: 0px 4px 12px rgba(0,0,0,0.1);
        }
        .login-container h1 {
            font-size: 1.8rem;
            margin-bottom: 20px;
            text-align: center;
        }
        .form-control {
            font-size: 0.9rem;
            padding: 8px 12px;
        }
        .btn {
            width: 100%;
        }
        .content {
            margin-left: 220px; /* push content to the right of sidebar */
            padding: 20px;
        }
    </style>
</head>
<body>
    <!-- Header / Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
        <div class="container-fluid">
            <!-- Logo + Title -->
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="/images/logo.png" alt="ResellVault Logo" width="40" height="40" class="me-2">
                ResellVault
            </a>
        </div>
    </nav>

    <!-- Sidebar -->
    <%- include('partials/sidebar') %>

    <!-- Main content -->
    <div class="content" id="content">
        <div class="login-container">
            <h1>Login</h1>

            <% if (errors && errors.length > 0) { %>
                <div class="alert alert-danger">
                    <% errors.forEach(function(error) { %>
                        <p><%= error %></p>
                    <% }); %>
                </div>
            <% } %>

            <% if (messages && messages.length > 0) { %>
                <div class="alert alert-success">
                    <% messages.forEach(function(message) { %>
                        <p><%= message %></p>
                    <% }); %>
                </div>
            <% } %>

            <form action="/login" method="POST">
                <div class="form-group mb-3">
                    <label for="email">Email:</label>
                    <input type="email" id="email" name="email" class="form-control" required>
                </div>
                <div class="form-group mb-3">
                    <label for="password">Password:</label>
                    <input type="password" id="password" name="password" class="form-control" required>
                </div>
                <button type="submit" class="btn btn-primary">Login</button>
            </form>

            <!-- Register link below form -->
            <div class="text-center mt-3">
                <small>Don't have an account? <a href="/register">Register here</a></small>
            </div>
        </div>
    </div>
</body>
</html>
