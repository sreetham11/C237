<!DOCTYPE html>
<html>
<head>
    <title>Register</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        /* Sidebar styling */
        .sidebar {
            height: 100vh;
            width: 200px;
            position: fixed;
            top: 56px; /* height of navbar */
            left: 0;
            background-color: rgba(52, 58, 64, 0.85); /* dark grey with transparency */
            padding-top: 20px;
        }
        .sidebar a {
            display: block;
            padding: 10px 20px;
            color: #f8f9fa; /* light text for contrast */
            text-decoration: none;
        }
        .sidebar a:hover {
            background-color: rgba(108, 117, 125, 0.9); /* lighter grey on hover */
        }
        .content {
            margin-left: 220px; /* push content to the right of sidebar */
            padding: 20px;
        }
    </style>
    <script>
        // Show/hide Admin Key field depending on role selection
        function toggleAdminKey() {
            const roleSelect = document.getElementById('role');
            const adminKeyField = document.getElementById('adminKeyField');
            if (roleSelect.value === 'admin') {
                adminKeyField.style.display = 'block';
            } else {
                adminKeyField.style.display = 'none';
            }
        }
    </script>
</head>
<body>
    <!-- Header / Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
        <div class="container-fluid">
            <!-- Logo + Title -->
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="/images/logo.png" alt="ResellVault Logo" width="40" height="40" class="me-2">
                ResellVault
            </a>
        </div>
    </nav>

    <!-- Sidebar (called from partial) -->
    <%- include('partials/sidebar') %>

    <!-- Main content -->
    <div class="content">
        <h1 class="mt-5">Register</h1>

        <!-- Error messages -->
        <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger">
                <% errors.forEach(function(error) { %>
                    <p><%= error %></p>
                <% }); %>
            </div>
        <% } %>

        <!-- Success messages -->
        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-success">
                <% messages.forEach(function(msg) { %>
                    <p><%= msg %></p>
                <% }); %>
            </div>
        <% } %>

        <form action="/register" method="POST" class="mt-4">
            <div class="form-group mb-3">
                <label for="username">Username:</label>
                <input type="text" id="username" name="username" class="form-control" required 
                <% if (formData && formData.username) { %> value="<%= formData.username %>" <% } %>>
            </div>

            <div class="form-group mb-3">
                <label for="email">Email:</label>
                <input type="email" id="email" name="email" class="form-control" required 
                <% if (formData && formData.email) { %> value="<%= formData.email %>" <% } %>>
            </div>

            <div class="form-group mb-3">
                <label for="password">Password:</label>
                <input type="password" id="password" name="password" class="form-control" required>
            </div>

            <div class="form-group mb-3">
                <label for="address">Address:</label>
                <input type="text" id="address" name="address" class="form-control" required 
                <% if (formData && formData.address) { %> value="<%= formData.address %>" <% } %>>
            </div>

            <div class="form-group mb-3">
                <label for="contact">Contact Number:</label>
                <input type="text" id="contact" name="contact" class="form-control" required 
                <% if (formData && formData.contact) { %> value="<%= formData.contact %>" <% } %>>
            </div>

            <!-- Role selection -->
            <div class="form-group mb-3">
                <label for="role">Role:</label>
                <select id="role" name="role" class="form-control" required onchange="toggleAdminKey()">
                    <option value="user" <% if (formData && formData.role === 'user') { %> selected <% } %>>User</option>
                    <option value="seller" <% if (formData && formData.role === 'seller') { %> selected <% } %>>Seller</option>
                    <option value="admin" <% if (formData && formData.role === 'admin') { %> selected <% } %>>Admin</option>
                </select>
            </div>

            <!-- Admin Key field (hidden unless Admin selected) -->
            <div class="form-group mb-3" id="adminKeyField" style="display:none;">
                <label for="adminKey">Admin Key:</label>
                <input type="password" id="adminKey" name="adminKey" class="form-control">
                <small class="form-text text-muted">Enter the admin key to register as Admin.</small>
            </div>

            <button type="submit" class="btn btn-primary">Register</button>
        </form>
    </div>

    <script>
        // Run once on page load to check if Admin was pre-selected
        toggleAdminKey();
    </script>
</body>
</html>
